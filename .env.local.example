# Copie este arquivo para ".env.local" (que já é ignorado pelo git) e
# preencha com os valores do SEU projeto Supabase do LANC:
# painel do Supabase → Settings → API.

# URL do projeto e chave "anon/public" — essas duas são seguras para expor
# no navegador, por isso levam o prefixo NEXT_PUBLIC_.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Chave "service_role" — NUNCA leva prefixo NEXT_PUBLIC_, nunca sobe para a
# Vercel, e só é usada por scripts locais (ex.: a skill criacao-de-noticias)
# que precisam ignorar as travas de RLS para publicar conteúdo.
SUPABASE_SERVICE_ROLE_KEY=
